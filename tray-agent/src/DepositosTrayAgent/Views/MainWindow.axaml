<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DepositosTrayAgent.Views.MainWindow"
        Width="1280"
        Height="40"
        MinWidth="900"
        MinHeight="36"
        Background="#0F172A"
        Foreground="White"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="Manual">
  <Border x:Name="RootBorder"
          Background="#111827"
          BorderBrush="#334155"
          BorderThickness="1"
          Padding="6,4">
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled">
      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Backend" VerticalAlignment="Center" FontSize="11" />
          <TextBox x:Name="BackendUrlBox"
                   Width="170"
                   Height="22"
                   Watermark="http://192.168.85.50:3000" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Dashboard" VerticalAlignment="Center" FontSize="11" />
          <TextBox x:Name="DashboardUrlBox"
                   Width="190"
                   Height="22"
                   Watermark="http://192.168.85.50:3000/kanban" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Agente" VerticalAlignment="Center" FontSize="11" />
          <TextBox x:Name="AgentNameBox"
                   Width="110"
                   Height="22"
                   Watermark="Nombre visible" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Grupo" VerticalAlignment="Center" FontSize="11" />
          <TextBox x:Name="AgentGroupBox"
                   Width="80"
                   Height="22"
                   Watermark="general" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Alias" VerticalAlignment="Center" FontSize="11" />
          <TextBox x:Name="MachineAliasBox"
                   Width="90"
                   Height="22"
                   Watermark="Opcional" />
        </StackPanel>

        <Button x:Name="SaveButton"
                Content="Guardar"
                Width="78"
                Height="22" />
        <Button x:Name="TestButton"
                Content="Probar"
                Width="70"
                Height="22" />
        <Button x:Name="OpenDashboardButton"
                Content="Abrir sistema"
                Width="98"
                Height="22" />

        <TextBlock x:Name="StatusTextBlock"
                   Text="Iniciando..."
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"
                   MaxWidth="240"
                   TextTrimming="CharacterEllipsis"
                   FontSize="11"
                   Opacity="0.85" />
      </StackPanel>
    </ScrollViewer>
  </Border>
</Window>
