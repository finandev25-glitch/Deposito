<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DepositosTrayAgent.Views.SupportAlertWindow"
        Width="360"
        Height="170"
        MinWidth="360"
        MinHeight="170"
        Background="Transparent"
        Foreground="White"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
  <Border x:Name="RootBorder"
          Background="#991B1B"
          BorderBrush="#FCA5A5"
          BorderThickness="1"
          Padding="10,8"
          CornerRadius="18">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
      <TextBlock x:Name="TitleText"
                 Grid.Row="0"
                 Grid.Column="0"
                 VerticalAlignment="Center"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="#FDE68A"
                 Margin="2,0,10,3"
                 Text="URGENTE!!" />

      <TextBlock x:Name="ReasonText"
                 Grid.Row="1"
                 Grid.Column="0"
                 VerticalAlignment="Center"
                 FontSize="22"
                 LineHeight="24"
                 Foreground="#E2E8F0"
                 TextWrapping="NoWrap"
                 TextTrimming="CharacterEllipsis"
                 Margin="2,0,10,3" />

      <TextBlock x:Name="CountdownText"
                 Grid.Row="2"
                 Grid.Column="0"
                 VerticalAlignment="Center"
                 FontSize="18"
                 Foreground="#FCA5A5"
                 Margin="2,0,10,3"
                 Text="Se cierra en 8 segundos" />

      <StackPanel Grid.Row="3"
                  Grid.ColumnSpan="2"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="6"
                  Margin="2,8,10,0">
        <Button x:Name="OpenDashboardButton"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                MinWidth="102"
                Height="30">
          <Border Background="#2563EB"
                  BorderBrush="#93C5FD"
                  BorderThickness="1"
                  CornerRadius="14"
                  Padding="12,6">
            <TextBlock Text="Abrir"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Button>
        <Button x:Name="DismissButton"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                MinWidth="88"
                Height="30">
          <Border Background="#334155"
                  BorderBrush="#94A3B8"
                  BorderThickness="1"
                  CornerRadius="14"
                  Padding="12,6">
            <TextBlock Text="Cerrar"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Button>
      </StackPanel>
    </Grid>
  </Border>
</Window>
