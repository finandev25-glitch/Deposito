<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DepositosTrayAgent.Views.SupportAlertWindow"
        Width="560"
        Height="40"
        MinHeight="36"
        Background="Transparent"
        Foreground="White"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
  <Border x:Name="RootBorder"
          Background="#991B1B"
          BorderBrush="#FCA5A5"
          BorderThickness="1"
          Padding="8,4"
          CornerRadius="18">
    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
      <TextBlock x:Name="ReasonText"
                 VerticalAlignment="Center"
                 FontSize="12"
                 LineHeight="14"
                 Foreground="#E2E8F0"
                 TextWrapping="NoWrap"
                 TextTrimming="CharacterEllipsis"
                 Margin="2,0,12,0" />

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Right"
                  Spacing="8">
        <Button x:Name="OpenDashboardButton"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                MinWidth="92"
                Height="24">
          <Border Background="#2563EB"
                  BorderBrush="#93C5FD"
                  BorderThickness="1"
                  CornerRadius="14"
                  Padding="10,4">
            <TextBlock Text="Abrir"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Button>
        <Button x:Name="DismissButton"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                MinWidth="72"
                Height="24">
          <Border Background="#334155"
                  BorderBrush="#94A3B8"
                  BorderThickness="1"
                  CornerRadius="14"
                  Padding="10,4">
            <TextBlock Text="Cerrar"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Button>
      </StackPanel>
    </Grid>
  </Border>
</Window>
