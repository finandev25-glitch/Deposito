{
    "compilerOptions": {
        "lib": [
            "deno.window"
        ],
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictBindCallApply": true,
        "strictPropertyInitialization": true,
        "noImplicitThis": true,
        "alwaysStrict": true
    },
    "imports": {
        "supabase": "https://esm.sh/@supabase/supabase-js@2.39.0"
    },
    "tasks": {
        "dev": "deno run --allow-all --watch index.ts"
    }
}