# Configuración de WhatsApp Cloud API
# Obtén estos valores de https://developers.facebook.com/apps/

# ID del número de teléfono de WhatsApp Business
VITE_WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui

# Token de acceso permanente de WhatsApp
VITE_WHATSAPP_ACCESS_TOKEN=tu_access_token_aqui

# Configuración de Chatwoot
# URL base de Chatwoot (sin slash al final)
VITE_CHATWOOT_BASE_URL=https://chatwoot-chatwoot.gnfcio.easypanel.host

# Configuración existente de Supabase (mantener)
VITE_SUPABASE_URL=tu_supabase_url
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key